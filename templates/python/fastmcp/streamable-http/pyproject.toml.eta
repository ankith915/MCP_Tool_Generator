[project]
name = "<%= it.serverName %>"
version = "<%= it.version %>"
requires-python = ">=3.12"
dependencies = [
    "mcp==1.27.1",
    "uvicorn>=0.24,<1",
    "structlog==25.3.0",
    "pydantic>=2,<3",
    "pytest>=8,<9",
]

[tool.ruff]
line-length = 100
target-version = "py312"

[tool.ruff.lint]
select = ["E", "F", "I"]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
