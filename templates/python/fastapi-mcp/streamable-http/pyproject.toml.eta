[project]
name = "<%= it.serverName %>"
version = "<%= it.version %>"
requires-python = ">=3.12"
dependencies = [
    "fastapi",
    "fastapi-mcp==0.4.0",
    "uvicorn>=0.24,<1",
    "structlog==25.3.0",
    "pydantic>=2,<3",
]

[dependency-groups]
dev = [
    "pytest>=8,<9",
    "httpx>=0.27,<1",
    "ruff>=0.8,<1",
]

[tool.ruff]
line-length = 100
target-version = "py312"

[tool.ruff.lint]
select = ["E", "F", "I"]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
