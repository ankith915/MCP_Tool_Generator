# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Adapter selection (POC defaults)
AUTH_PROVIDER=noop
STORAGE_PROVIDER=local
RATE_LIMIT_PROVIDER=memory

# Chat-agent flow (OpenAI). Leave CHAT_FLOW_ENABLED=false to keep wizard-only deploy.
CHAT_FLOW_ENABLED=false
# OPENAI_API_KEY=sk-...
# OPENAI_CLARIFY_MODEL=gpt-4.1-mini
# OPENAI_PLAN_MODEL=o4-mini
# OPENAI_CODEGEN_MODEL=gpt-4.1-mini
# OPENAI_MAX_TOKENS=8192

